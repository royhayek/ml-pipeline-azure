<!--
  APIM Consumption tier policy for the Weather ML API.
  Apply at the API level via the az rest API (see docs/deployment.md section 9).
  Consumption tier uses rate-limit / quota (not the -by-key variants).
-->
<policies>
  <inbound>
    <base />

    <check-header name="Ocp-Apim-Subscription-Key" failed-check-httpcode="401"
                  failed-check-error-message="Subscription key missing or invalid."
                  ignore-case="true" />

    <rate-limit calls="100" renewal-period="60" />

    <set-backend-service
      base-url="https://ca-mlapi.orangesky-cc1a99c3.switzerlandnorth.azurecontainerapps.io" />

    <set-header name="X-Forwarded-Via" exists-action="override">
      <value>APIM-Consumption</value>
    </set-header>
  </inbound>

  <backend>
    <base />
  </backend>

  <outbound>
    <base />
  </outbound>

  <on-error>
    <base />
  </on-error>
</policies>
