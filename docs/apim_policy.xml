<!--
  APIM Consumption tier policy for the Weather ML API.
  Apply at the API level via:
    az apim api policy create \
      --service-name apim-mlpipeline-aa8229 \
      --resource-group rg-mlpipeline-prod \
      --api-id mlapi \
      --value @docs/apim_policy.xml
-->
<policies>
  <inbound>
    <base />

    <!-- Require valid subscription key -->
    <check-header name="Ocp-Apim-Subscription-Key" failed-check-httpcode="401"
                  failed-check-error-message="Subscription key missing or invalid."
                  ignore-case="true" />

    <!-- Rate limit: 100 calls per 60 seconds per subscription key -->
    <rate-limit-by-key
      calls="100"
      renewal-period="60"
      counter-key="@(context.Request.Headers.GetValueOrDefault(&quot;Ocp-Apim-Subscription-Key&quot;, &quot;anonymous&quot;))"
      increment-condition="@(context.Response.StatusCode >= 200 &amp;&amp; context.Response.StatusCode &lt; 300)" />

    <!-- Quota: 10 000 calls per hour per subscription key -->
    <quota-by-key
      calls="10000"
      renewal-period="3600"
      counter-key="@(context.Request.Headers.GetValueOrDefault(&quot;Ocp-Apim-Subscription-Key&quot;, &quot;anonymous&quot;))" />

    <!-- Forward to Container Apps backend -->
    <set-backend-service
      base-url="https://ca-mlapi.orangesky-cc1a99c3.switzerlandnorth.azurecontainerapps.io" />

    <!-- Add correlation header -->
    <set-header name="X-Forwarded-Via" exists-action="override">
      <value>APIM-Consumption</value>
    </set-header>
  </inbound>

  <backend>
    <base />
  </backend>

  <outbound>
    <base />
    <!-- Expose rate limit headers to clients -->
    <set-header name="X-Rate-Limit-Remaining" exists-action="override">
      <value>@(context.Variables.GetValueOrDefault("remainingCallsPerSubscription", ""))</value>
    </set-header>
  </outbound>

  <on-error>
    <base />
    <return-response>
      <set-status code="@(context.Response.StatusCode)" reason="@(context.Response.StatusReason)" />
      <set-header name="Content-Type" exists-action="override">
        <value>application/json</value>
      </set-header>
      <set-body>@("{\"error\": \"" + context.LastError.Message + "\"}")</set-body>
    </return-response>
  </on-error>
</policies>
